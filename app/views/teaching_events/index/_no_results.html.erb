<div class="teaching-events__events teaching-events__events--none" role="alert">
  <h2 class="heading-m">
    No events found
  </h2>

  <% if @event_search.in_person_only? || (@event_search.distance.present? && @event_search.distance > 0) %>
    <p><strong>Why not try:</strong></p>
    <ul>
      <% if @event_search.distance.present? && @event_search.distance > 0 %>
        <li>expanding your search area</li>
      <% end %>
      <% if @event_search.in_person_only? %>
        <li>changing event type - <%= link_to("online events", events_path(add_online_events(params))) %> may be available</li>
      <% end %>
      <li><%= link_to("clearing your filters", events_path) %> to start again</li>
    </ul>
  <% else %>
    <p>There are no events planned.</p>
    <p>Try checking again in a few weeks to see new provider events on offer.</p>
  <% end %>
</div>
