<div class="checklist-collage">
  <div class="checklist-grid">
    <% checklist.each do |item| %>
      <div class="checklist-content">
        <i class="icon-arrow icon-arrow--gitlilac"></i>
      </div>
      <%= tag.div(safe_join([tag.strong(item)]), class:"checklist-content") %>
    <% end %>
    <div class="checklist-footer">
      <%= link_to(cta[:text], cta[:link], class: "button") if cta.present? %>
      <%= content %>
    </div>
  </div>

  <%= tag.div(class: image_classes) do %>
    <%= images %>
  <% end %>
</div>
