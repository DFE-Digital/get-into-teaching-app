<%= tag.div(class: "image-block promos") do %>
  <%= tag.div class: image_classes do %>
    <%= image_pack_tag("images/#{image}", alt: "") %>
  <% end %>
  <%= tag.h2(class: "heading--overlap heading--highlight-#{title_color} heading--margin-top-0 heading-xl") do %>
    <%= tag.span(title) %>
  <% end %>

  <div>
    <p><%= text %></p>
    <%= link_to link_text, link_target, class: "button", role: "button", data: { "promo-type": "events" } if link_text.present? && link_target.present? %>
  </div>
<% end %>
